local function makeDraggable(obj, parent, saveKey)
	if not obj or not parent then
		return
	end
	local dragging, dragStart, startPos, moved
	obj.InputBegan:Connect(function(input)
		if DesyncBundle.Flags.UiLock then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			moved = false
			dragStart = input.Position
			startPos = parent.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			parent.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
			moved = true
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
			if moved and saveKey then
				uiPosState[saveKey] = {
					xs = parent.Position.X.Scale,
					xo = parent.Position.X.Offset,
					ys = parent.Position.Y.Scale,
					yo = parent.Position.Y.Offset,
				}
				saveConfig()
			end
		end
	end)
end

