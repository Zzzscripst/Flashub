-- Same as script-b.lua "Main Speed Loop": speed customizer applies HRP velocity when moving.
-- Without this, ENABLE + walk/steal values only affect desync's follower loop, not normal play.
RunService.Heartbeat:Connect(function()
	local speedMenuOn = DesyncBundle.Flags.Speed and DesyncBundle.SpeedSettings.Enabled
	if not speedMenuOn then
		return
	end
	if DesyncBundle.autoPlayRunning then
		return
	end
	local character = LocalPlayer.Character
	if not character then
		return
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local root = character:FindFirstChild("HumanoidRootPart")
	if not root or not humanoid or humanoid.Health <= 0 then
		return
	end
	if humanoid.MoveDirection.Magnitude <= 0 then
		return
	end
	local moveDir = humanoid.MoveDirection
	local spd = getMovementSpeedForPhysics(character)
	root.AssemblyLinearVelocity = Vector3.new(
		moveDir.X * spd,
		root.AssemblyLinearVelocity.Y,
		moveDir.Z * spd
	)
end)

