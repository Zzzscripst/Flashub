local function setRaknetDesync(on)
	pcall(function()
		local g = (getgenv and getgenv()) or _G
		local r = rawget(g, "raknet")
		if r == nil and type(_G) == "table" then
			r = rawget(_G, "raknet")
		end
		if type(r) == "table" and type(r.desync) == "function" then
			r.desync(on)
		end
	end)
	pcall(function()
		local g = (getgenv and getgenv()) or _G
		local n = rawget(g, "network")
		if type(n) == "table" and type(n.desync) == "function" then
			n.desync(on)
		end
	end)
	pcall(function()
		local g = (getgenv and getgenv()) or _G
		local f = rawget(g, "fluxus")
		if type(f) == "table" and type(f.network_desync) == "function" then
			f.network_desync(on)
		end
	end)
end

local function teardownDesyncPhys()
	if desyncConn then
		desyncConn:Disconnect()
		desyncConn = nil
	end
	pcall(function()
		if desyncInvisiblePart then
			desyncInvisiblePart:Destroy()
		end
	end)
	desyncInvisiblePart = nil
	for _, inst in ipairs(workspace:GetChildren()) do
		if inst.Name == "DarkHub_DesyncPos" then
			pcall(function()
				inst:Destroy()
			end)
		end
	end
	local ch = LocalPlayer.Character
	local hum = ch and ch:FindFirstChildOfClass("Humanoid")
	if hum and desyncOriginalWalk ~= nil then
		pcall(function()
			hum.WalkSpeed = desyncOriginalWalk
		end)
	end
	desyncOriginalWalk = nil
	desyncLastWalkWritten = nil
	desyncLastSnapTime = 0
	desyncPostSimLastT = 0
	desyncLinearVelocity = nil
end

local function updateDesyncMovement(dt)
	dt = (type(dt) == "number" and dt > 0 and dt < 0.5) and dt or (1 / 60)
	local blend = math.clamp(dt * DESYNC_VEL_SMOOTH_HZ, 0.08, 0.5)
	local function applySmoothedHorizontal(targetVx, targetVz)
		local cur = DesyncPhys.invisiblePart.AssemblyLinearVelocity
		local vy = cur.Y
		local nvx = cur.X + (targetVx - cur.X) * blend
		local nvz = cur.Z + (targetVz - cur.Z) * blend
		local v = Vector3.new(nvx, vy, nvz)
		if DesyncPhys.linearVelocity and DesyncPhys.linearVelocity.Parent then
			DesyncPhys.linearVelocity.VectorVelocity = v
		else
			DesyncPhys.invisiblePart.AssemblyLinearVelocity = v
		end
	end
	if not desyncActive or not DesyncPhys.invisiblePart or not DesyncPhys.invisiblePart.Parent then
		return
	end
	local char = LocalPlayer.Character
	if not char or DesyncPhys.invisiblePart.Parent ~= char then
		return
	end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not humanoid or not hrp then
		return
	end
	if humanoid.Health <= 0 then
		pcall(function()
			if DesyncPhys.originalWalk ~= nil then
				humanoid.WalkSpeed = DesyncPhys.originalWalk
			end
		end)
		DesyncPhys.lastWalkWritten = nil
		local vy0 = DesyncPhys.invisiblePart.AssemblyLinearVelocity.Y
		local zv = Vector3.new(0, vy0, 0)
		if DesyncPhys.linearVelocity and DesyncPhys.linearVelocity.Parent then
			DesyncPhys.linearVelocity.VectorVelocity = zv
		else
			DesyncPhys.invisiblePart.AssemblyLinearVelocity = zv
		end
		return
	end

	if DesyncBundle.autoPlayRunning then
		local vy = DesyncPhys.invisiblePart.AssemblyLinearVelocity.Y
		local v = hrp.AssemblyLinearVelocity
		local nv = Vector3.new(v.X, vy, v.Z)
		if DesyncPhys.linearVelocity and DesyncPhys.linearVelocity.Parent then
			DesyncPhys.linearVelocity.VectorVelocity = nv
		else
			DesyncPhys.invisiblePart.AssemblyLinearVelocity = nv
		end
		return
	end

	local moveDir = humanoid.MoveDirection
	local driveUnit
	local moving
	if moveDir.Magnitude > 0.02 then
		driveUnit = moveDir.Unit
		moving = true
	else
		moving = false
	end

	local speedCustomizerOn = DesyncBundle.Flags.Speed and DesyncBundle.SpeedSettings.Enabled

	if speedCustomizerOn then
		if not DesyncBundle.autoPlayRunning then
			pcall(function()
				if DesyncPhys.originalWalk ~= nil then
					humanoid.WalkSpeed = DesyncPhys.originalWalk
				end
			end)
		end
		local targetSpeed = getDesyncCappedSpeed(char)
		if moving then
			applySmoothedHorizontal(driveUnit.X * targetSpeed, driveUnit.Z * targetSpeed)
		else
			applySmoothedHorizontal(0, 0)
		end
	else
		local reportW, driveS = getDesyncSplitWalkAndDrive(char)
		if moving then
			if not DesyncBundle.autoPlayRunning then
				if DesyncPhys.lastWalkWritten == nil or math.abs(DesyncPhys.lastWalkWritten - reportW) > 0.28 then
					pcall(function()
						humanoid.WalkSpeed = reportW
					end)
					DesyncPhys.lastWalkWritten = reportW
				end
			end
			applySmoothedHorizontal(driveUnit.X * driveS, driveUnit.Z * driveS)
		else
			if not DesyncBundle.autoPlayRunning then
				if DesyncPhys.lastWalkWritten == nil or math.abs(DesyncPhys.lastWalkWritten - reportW) > 0.35 then
					pcall(function()
						humanoid.WalkSpeed = reportW
					end)
					DesyncPhys.lastWalkWritten = reportW
				end
			end
			applySmoothedHorizontal(0, 0)
		end
	end
end

snapDesyncFollowerIfActive = function()
	if not desyncActive or not desyncInvisiblePart or not desyncInvisiblePart.Parent then
		return
	end
	local c = LocalPlayer.Character
	if not c or desyncInvisiblePart.Parent ~= c then
		return
	end
	local h = c:FindFirstChild("HumanoidRootPart")
	if not h then
		return
	end
	local now = tick()
	if desyncLastSnapTime > 0 and (now - desyncLastSnapTime) < DESYNC_SNAP_MIN_INTERVAL then
		return
	end
	desyncLastSnapTime = now
	desyncInvisiblePart.CFrame = h.CFrame * CFrame.new(0, 0, -2.85)
end

local function setupDesyncCharacter(char)
	teardownDesyncPhys()
	if not desyncActive then
		return
	end
	local humanoid = char:WaitForChild("Humanoid", 15)
	local hrp = char:WaitForChild("HumanoidRootPart", 15)
	if not humanoid or not hrp then
		return
	end

	DesyncPhys.originalWalk = humanoid.WalkSpeed
	DesyncPhys.lastWalkWritten = nil
	DesyncPhys.linearVelocity = nil

	DesyncPhys.invisiblePart = Instance.new("Part")
	DesyncPhys.invisiblePart.Name = "DarkHub_DesyncFollower"
	DesyncPhys.invisiblePart.Size = Vector3.new(2, 1, 2)
	DesyncPhys.invisiblePart.Transparency = 1
	DesyncPhys.invisiblePart.CanCollide = false
	DesyncPhys.invisiblePart.Anchored = false
	DesyncPhys.invisiblePart.Massless = true
	DesyncPhys.invisiblePart.Parent = char

	local dhAtt = Instance.new("Attachment")
	dhAtt.Name = "DH_DesyncDrive"
	dhAtt.Parent = DesyncPhys.invisiblePart
	local lv = Instance.new("LinearVelocity")
	lv.Name = "DH_DesyncLinearVelocity"
	lv.Attachment0 = dhAtt
	lv.RelativeTo = Enum.ActivationRelativeTo.World
	lv.MaxForce = DesyncTuning.lvMaxForce
	lv.VectorVelocity = Vector3.zero
	lv.Parent = DesyncPhys.invisiblePart
	DesyncPhys.linearVelocity = lv

	local welded = false
	pcall(function()
		local w = Instance.new("Weld")
		w.Name = "DH_DesyncWeld"
		w.Part0 = hrp
		w.Part1 = DesyncPhys.invisiblePart
		w.C0 = CFrame.new(0, 0, -3.85)
		w.Parent = DesyncPhys.invisiblePart
		welded = true
	end)
	if not welded then
		DesyncPhys.invisiblePart.CFrame = hrp.CFrame * CFrame.new(0, 0, -3.85)
		local wc = Instance.new("WeldConstraint")
		wc.Name = "DH_DesyncWeldConstraint"
		wc.Part0 = hrp
		wc.Part1 = DesyncPhys.invisiblePart
		wc.Parent = DesyncPhys.invisiblePart
	end

	task.defer(function()
		DesyncPhys.lastSnapTime = 0
		snapDesyncFollowerIfActive()
		local ps = RunService.PostSimulation
		if ps then
			ps:Wait()
		else
			RunService.Heartbeat:Wait()
		end
		snapDesyncFollowerIfActive()
	end)
	task.delay(0.15, snapDesyncFollowerIfActive)

	DesyncPhys.postSimLastT = os.clock()
	local stepper = RunService.PostSimulation or RunService.Heartbeat
	DesyncPhys.conn = stepper:Connect(function()
		local now = os.clock()
		local dt = math.clamp(now - DesyncPhys.postSimLastT, 1 / 240, 1 / 25)
		DesyncPhys.postSimLastT = now
		updateDesyncMovement(dt)
	end)

	local refreshAccum = 0
	if DesyncPhys.networkRefreshConn then
		DesyncPhys.networkRefreshConn:Disconnect()
	end
	DesyncPhys.networkRefreshConn = RunService.Heartbeat:Connect(function(dt)
		if not desyncActive then
			return
		end
		refreshAccum += typeof(dt) == "number" and dt or (1 / 60)
		if refreshAccum < 1.2 then
			return
		end
		refreshAccum = 0
		reapplyDesyncHubFFlagsIfActive()
	end)

	DesyncBundle.fflagLastApplyT = 0
	applyDesyncHubFFlags()
	task.defer(function()
		if desyncActive and LocalPlayer.Character == char then
			DesyncBundle.fflagLastApplyT = 0
			applyDesyncHubFFlags()
		end
	end)
	task.delay(0.45, function()
		if desyncActive and LocalPlayer.Character == char then
			DesyncBundle.fflagLastApplyT = 0
			applyDesyncHubFFlags()
		end
	end)
	task.delay(0.55, function()
		if desyncActive and LocalPlayer.Character == char then
			reapplyDesyncHubFFlagsIfActive()
		end
	end)
	task.delay(1.35, function()
		if desyncActive and LocalPlayer.Character == char then
			reapplyDesyncHubFFlagsIfActive()
		end
