function DesyncBundle.stopDesyncSession()
	setRaknetDesync(false)
	desyncActive = false
	teardownDesyncPhys()
	DesyncPhys.savedSpeed = nil
	local ui = DesyncBundle.hooks.setUiActive
	if type(ui) == "function" then
		ui(false)
	end
	DesyncBundle.hooks.saveAutoConfig()
end

function DesyncBundle.startDesyncSession()
	if desyncActive then
		return
	end
	local stopAp = DesyncBundle.hooks.stopAutoPlayNow
	if type(stopAp) == "function" then
		stopAp(false)
	end
	teardownDesyncPhys()
	DesyncPhys.savedSpeed = nil
	DesyncBundle.fflagLastApplyT = 0
	applyDesyncHubFFlags()
	task.delay(0.45, function()
		if desyncActive then
			DesyncBundle.fflagLastApplyT = 0
			applyDesyncHubFFlags()
		end
	end)
	task.delay(1.15, function()
		if desyncActive then
			DesyncBundle.fflagLastApplyT = 0
			applyDesyncHubFFlags()
		end
	end)
	task.delay(2.2, function()
		if desyncActive then
			DesyncBundle.fflagLastApplyT = 0
			applyDesyncHubFFlags()
		end
	end)
	setRaknetDesync(true)
	desyncActive = true
	local ui = DesyncBundle.hooks.setUiActive
	if type(ui) == "function" then
		ui(true)
	end
	DesyncBundle.hooks.saveAutoConfig()
	task.spawn(function()
		respawnPlayerForDesync(LocalPlayer)
		for _, delay in ipairs({ 0.12, 0.45, 1.2 }) do
			task.wait(delay)
			if not desyncActive then
				return
			end
			local ch = LocalPlayer.Character
			if ch and (not DesyncPhys.invisiblePart or not DesyncPhys.invisiblePart.Parent) then
				setupDesyncCharacter(ch)
				if DesyncPhys.invisiblePart and DesyncPhys.invisiblePart.Parent then
					break
				end
			end
		end
		task.wait(3.5)
		if not desyncActive then
			return
		end
		local ch = LocalPlayer.Character
		if ch and (not DesyncPhys.invisiblePart or not DesyncPhys.invisiblePart.Parent) then
			setupDesyncCharacter(ch)
		end
	end)
end

function DesyncBundle.toggleDesyncSession()
	if desyncActive then
		DesyncBundle.stopDesyncSession()
	else
		DesyncBundle.startDesyncSession()
	end
end

