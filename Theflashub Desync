local function getActiveSpeed(char)
	if DesyncBundle.stealState.isStealing then
		return DesyncBundle.SpeedSettings.Steal
	end
	if LocalPlayer:GetAttribute("Stealing") then
		return DesyncBundle.SpeedSettings.Steal
	end
	if char and char:GetAttribute("Stealing") then
		return DesyncBundle.SpeedSettings.Steal
	end
	if isCarryingOrGrab(char) then
		return DesyncBundle.SpeedSettings.Steal
	end
	return DesyncBundle.SpeedSettings.Speed
end

